---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const notes = (await getCollection('pages')).sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<Layout
	title={`Notes | ${notes.length ? 'Maria' : 'Portfolio'}`}
	description="Sample MDX notes and writing entries powered by Astro content collections."
>
	<a class="skip-link" href="#main-content">Skip to content</a>

	<div class="page">
		<SiteHeader />

		<main id="main-content" class="notes-page">
			<div class="notes-intro">
				<p class="notes-eyebrow">Notes</p>
				<h1>Writing and MDX content now have a real home in the theme.</h1>
				<p>
					Use this section for essays, longer case studies, product thinking, or simple
					writing samples.
				</p>
			</div>

			<div class="notes-list">
				{
					notes.map((note) => (
						<a class="note-card" href={`/notes/${note.id}/`}>
							<h2>{note.data.title}</h2>
							<p>{note.data.description ?? 'Open this entry to read the full note.'}</p>
						</a>
					))
				}
			</div>
		</main>
	</div>
</Layout>

<style>
	.page {
		position: relative;
		width: min(calc(100% - 3rem), 78rem);
		margin: 0 auto;
		padding: 1.25rem 0 5rem;
	}

	.notes-page {
		padding: 5rem 0 2rem;
	}

	.notes-intro {
		max-width: 42rem;
	}

	.notes-eyebrow {
		margin: 0 0 0.75rem;
		font-size: 0.95rem;
		font-style: italic;
		font-weight: 500;
		color: var(--muted-foreground);
	}

	h1,
	h2 {
		margin: 0;
		letter-spacing: -0.05em;
	}

	h1 {
		font-size: clamp(2.4rem, 4vw, 4rem);
		line-height: 1.04;
	}

	.notes-intro p:last-child {
		margin: 1rem 0 0;
		font-size: 1.08rem;
		line-height: 1.65;
		color: var(--muted-foreground);
	}

	.notes-list {
		display: grid;
		gap: 1rem;
		margin-top: 2.5rem;
	}

	.note-card {
		display: grid;
		gap: 0.6rem;
		padding: 1.4rem;
		background: var(--card);
		border: 1px solid var(--border);
		border-radius: 1.1rem;
		text-decoration: none;
		box-shadow: var(--shadow-soft);
		transition:
			transform 140ms ease,
			border-color 140ms ease;
	}

	.note-card:hover,
	.note-card:focus-visible {
		transform: translateY(-2px);
		border-color: var(--border-strong);
	}

	.note-card h2 {
		font-size: clamp(1.35rem, 2vw, 1.65rem);
		line-height: 1.12;
	}

	.note-card p {
		margin: 0;
		font-size: 1rem;
		line-height: 1.65;
		color: var(--muted-foreground);
	}

	@media (max-width: 720px) {
		.page {
			width: min(calc(100% - 1.5rem), 78rem);
			padding-top: 1rem;
		}

		.notes-page {
			padding-top: 3.5rem;
		}
	}
</style>
